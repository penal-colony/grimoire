{
  "manifest_version": 3,
  "name": "Grimoire",
  "version": "2.0.0",
  "description": "Inject lorebooks into JanitorAI chats. Your API key never leaves your browser.",
  "permissions": [
    "sidePanel",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://janitorai.com/*",
    "https://www.janitorai.com/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://janitorai.com/*", "https://www.janitorai.com/*"],
      "js": ["content/content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": ["https://janitorai.com/*", "https://www.janitorai.com/*"],
      "js": ["lib/lorebook.js", "content/inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
